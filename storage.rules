rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function isAssignedDriver(orderId) {
      return signedIn()
        && request.auth.token.role == "driver"
        && firestore.get(/databases/(default)/documents/orders/$(orderId)).data.driverId == request.auth.token.driverId;
    }

    match /evidence/{orderId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && (isAdmin() || isAssignedDriver(orderId))
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
