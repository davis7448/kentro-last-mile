rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : null;
    }

    function isAdmin() {
      return role() == "admin";
    }

    function isSeller(sellerId) {
      return role() == "seller" && request.auth.token.sellerId == sellerId;
    }

    function isDriver(driverId) {
      return role() == "driver" && request.auth.token.driverId == driverId;
    }

    function isMessenger(messengerId) {
      return role() == "messenger" && request.auth.token.messengerId == messengerId;
    }

    function sellerOrderCreate() {
      return isSeller(request.resource.data.sellerId)
        && request.resource.data.driverId == null
        && request.resource.data.status in ["ready_to_assign", "address_risk"]
        && request.resource.data.evidence.size() == 0;
    }

    function sellerOrderNoopUpdate() {
      return isSeller(resource.data.sellerId)
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([]);
    }

    function sellerOrderLabelUpdate() {
      return isSeller(resource.data.sellerId)
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "labelPrintedAt",
          "labelPrintedBy",
          "labelPrintCount",
          "updatedAt"
        ]);
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /cities/{cityId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /zones/{zoneId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow read: if isAdmin() || isSeller(sellerId);
      allow write: if isAdmin();
    }

    match /drivers/{driverId} {
      allow read: if isAdmin() || isDriver(driverId);
      allow write: if isAdmin();
    }

    match /messengers/{messengerId} {
      allow read: if isAdmin()
        || isMessenger(messengerId)
        || (role() == "driver" && resource.data.leaderDriverId == request.auth.token.driverId);
      allow create, update, delete: if isAdmin()
        || (role() == "driver" && request.resource.data.leaderDriverId == request.auth.token.driverId);
    }

    match /pickupBatches/{batchId} {
      allow read: if isAdmin()
        || (role() == "driver" && resource.data.driverId == request.auth.token.driverId);
      allow write: if isAdmin()
        || (role() == "driver" && request.resource.data.driverId == request.auth.token.driverId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin()
        || isSeller(resource.data.sellerId)
        || isDriver(resource.data.driverId)
        || isMessenger(resource.data.messengerId)
        || (role() == "driver" && resource.data.driverId == null && resource.data.status == "ready_to_assign");
      allow create: if isAdmin() || sellerOrderCreate();
      allow update: if isAdmin()
        || isDriver(resource.data.driverId)
        || isMessenger(resource.data.messengerId)
        || (
          role() == "driver"
          && resource.data.driverId == null
          && request.resource.data.driverId == request.auth.token.driverId
          && request.resource.data.status in ["picked_up", "assigned"]
        )
        || sellerOrderLabelUpdate()
        || sellerOrderNoopUpdate();
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isAdmin() || isSeller(resource.data.sellerId);
      allow write: if isAdmin();
    }

    match /walletEntries/{entryId} {
      allow read: if isAdmin()
        || (resource.data.ownerType == "seller" && isSeller(resource.data.ownerId))
        || (resource.data.ownerType == "driver" && isDriver(resource.data.ownerId));
      allow write: if isAdmin();
    }

    match /settlements/{settlementId} {
      allow read: if isAdmin()
        || (resource.data.kind == "seller" && isSeller(resource.data.ownerId))
        || (resource.data.kind == "driver" && isDriver(resource.data.ownerId));
      allow write: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read: if isAdmin() || isSeller(resource.data.sellerId);
      allow create: if isAdmin() || isSeller(request.resource.data.sellerId);
      allow update: if isAdmin() || isSeller(resource.data.sellerId);
      allow delete: if isAdmin();
    }

    match /auditEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /shopifyStores/{storeId} {
      allow read: if isAdmin() || isSeller(resource.data.sellerId);
      allow write: if isAdmin();
    }

    match /storeWebhookConfigs/{configId} {
      allow read: if isAdmin() || isSeller(resource.data.sellerId);
      allow write: if isAdmin();
    }

    match /storeWebhookSamples/{sampleId} {
      allow read: if isAdmin() || isSeller(resource.data.sellerId);
      allow write: if false;
    }

    match /shopifyInstallRequests/{requestId} {
      allow read: if isAdmin() || isSeller(resource.data.sellerId);
      allow create: if isSeller(request.resource.data.sellerId)
        && request.resource.data.status == "requested"
        && !("installLink" in request.resource.data);
      allow update: if isAdmin()
        || (
          isSeller(resource.data.sellerId)
          && resource.data.status == "requested"
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data.status == "requested"
          && !("installLink" in request.resource.data)
        );
      allow delete: if isAdmin();
    }

    match /shopifySyncIssues/{issueId} {
      allow read: if isAdmin() || isSeller(resource.data.sellerId);
      allow write: if false;
    }

    match /shopifyStoreSecrets/{storeId} {
      allow read, write: if false;
    }

    match /shopifyOAuthStates/{stateId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
